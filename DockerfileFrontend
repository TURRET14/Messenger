FROM node AS build

WORKDIR /app
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

COPY frontend/ .
ARG VITE_API_BASE_URL=https://94.29.32.133
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
RUN npm run build

FROM python

WORKDIR /app
COPY frontend_server/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY frontend_server/app ./app
COPY --from=build /app/dist ./app/static

ENV FRONTEND_STATIC_PORT=8080
EXPOSE 8080

CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${FRONTEND_STATIC_PORT:-8080}"]
