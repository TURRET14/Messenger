# =============================================================================
#  Пример конфигурации Мессенджера
#
#  Как развернуть:
#    1. Скопируйте этот файл в .env.
#    2. Заполните блоки «ПУБЛИЧНЫЙ АДРЕС» и «АДМИН / ПОЧТА» своими значениями.
#    3. (Прод) Поменяйте все пароли/секреты на свои.
#    4. Запустите:                     docker compose up -d --build
#
#  ВАЖНО: производные значения (полный URL фронтенда, адрес API,
#  имя TLS-сертификата, поля SMTP) НЕ дублируются здесь — они
#  собираются автоматически из переменных ниже в docker-compose.yaml.
#  Чтобы сменить адрес или почту, правится ТОЛЬКО один блок.
#
#  Файл .env добавлен в .gitignore и в репозиторий не попадает —
#  храните реальные секреты только локально / в секрет-менеджере.
# =============================================================================

# -----------------------------------------------------------------------------
#  ПУБЛИЧНЫЙ АДРЕС (единственное место смены IP/домена)
#
#  PUBLIC_HOST   — IP или домен, по которому сервис доступен снаружи
#                  (например: example.com или 203.0.113.10).
#  PUBLIC_SCHEME — http или https. Для https Caddy сам получит
#                  сертификат Let's Encrypt (нужен публичный домен/IP
#                  и открытые порты 80/443).
#
#  Из этих двух значений docker-compose.yaml собирает:
#    FRONTEND_URL      = ${PUBLIC_SCHEME}://${PUBLIC_HOST}  (backend)
#    VITE_API_BASE_URL = ${PUBLIC_SCHEME}://${PUBLIC_HOST}  (frontend)
#    SSL_SERVER_NAME   = ${PUBLIC_HOST}                     (Caddy/TLS)
# -----------------------------------------------------------------------------
PUBLIC_SCHEME=https
PUBLIC_HOST=your-domain-or-ip

# -----------------------------------------------------------------------------
#  АДМИН / ПОЧТА (единственное место смены адреса почты)
#
#  ADMIN_EMAIL   — контакт для Let's Encrypt (Caddy) и одновременно
#                  адрес отправителя / логин SMTP.
#  SMTP_HOSTNAME — SMTP-сервер почтового провайдера.
#  SMTP_PASSWORD — пароль приложения для SMTP (НЕ основной пароль почты;
#                  создаётся в настройках почтового ящика).
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
SMTP_HOSTNAME=smtp.example.com
SMTP_PASSWORD=change-me-smtp-app-password

# -----------------------------------------------------------------------------
#  Имя сервиса (отображается в UI и письмах)
# -----------------------------------------------------------------------------
SERVICE_PUBLIC_NAME=Мессенджер

# -----------------------------------------------------------------------------
#  PostgreSQL (в проде задайте надёжные значения)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=messenger_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
#  MinIO (объектное хранилище; в проде задайте надёжные значения)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_ENDPOINT=minio:9000

# -----------------------------------------------------------------------------
#  Redis (в проде задайте надёжный пароль)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change-me-redis-password
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
#  Порты сервисов
#  Caddy выступает обратным прокси и терминирует TLS (HTTP/HTTPS).
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=8080
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
